@model UdemyCarBook.Dto.ReservationDtos.UpdateReservationDto
@{
    ViewData["Title"] = "Rezervasyon Güncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-edit text-primary me-2 fa-lg"></i>
                            <h4 class="card-title m-0 font-weight-bold">Rezervasyon Detaylarını Düzenle</h4>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        @* Formun yeni rotamız olan AdminReservation'a gitmesi için action ekledik *@
                        <form method="post" action="/Admin/AdminReservation/EditReservation/@Model.ReservationID">

                            @Html.HiddenFor(x => x.ReservationID)
                            @Html.HiddenFor(x => x.AppUserId)
                            @Html.HiddenFor(x => x.Age)
                            @Html.HiddenFor(x => x.DriverLicenseNumber)
                            @Html.HiddenFor(x => x.Email)
                            @Html.HiddenFor(x => x.Description)

                            <h5 class="text-muted border-bottom pb-2 mb-3">Araç ve Lokasyon Bilgileri</h5>
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label font-weight-bold">Kiralanacak Araç</label>
                                        @Html.DropDownListFor(x => x.CarID, (SelectList)ViewBag.CarList, "Araç Seçiniz", new { @class = "form-select border-primary" })
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="form-label font-weight-bold">Alış Lokasyonu</label>
                                        @Html.DropDownListFor(x => x.PickUpLocationID, (SelectList)ViewBag.LocationList, "Seçiniz", new { @class = "form-select" })
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="form-label font-weight-bold">İade Lokasyonu</label>
                                        @Html.DropDownListFor(x => x.DropOffLocationID, (SelectList)ViewBag.LocationList, "Seçiniz", new { @class = "form-select" })
                                    </div>
                                </div>
                            </div>

                            <h5 class="text-muted border-bottom pb-2 mb-3">Zaman ve Müşteri Bilgileri</h5>
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label font-weight-bold">Alış Tarihi</label>
                                        <input type="datetime-local" asp-for="PickUpFull" class="form-control"
                                               value="@Model.PickUpFull.ToString("yyyy-MM-ddTHH:mm")" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label font-weight-bold">İade Tarihi</label>
                                        <input type="datetime-local" asp-for="DropOffFull" class="form-control"
                                               value="@Model.DropOffFull.ToString("yyyy-MM-ddTHH:mm")" />
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="form-label font-weight-bold">Müşteri Adı</label>
                                        <input type="text" asp-for="Name" class="form-control bg-light" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="form-label font-weight-bold">Müşteri Soyadı</label>
                                        <input type="text" asp-for="Surname" class="form-control bg-light" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="form-label font-weight-bold">Telefon</label>
                                        <input type="text" asp-for="Phone" class="form-control" />
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label class="form-label font-weight-bold text-primary">Rezervasyon Durumu</label>
                                        <select asp-for="Status" class="form-select fw-bold border-primary text-primary">
                                            <option value="Beklemede">🟡 Beklemede</option>
                                            <option value="Onaylandı">🟢 Onaylandı</option>
                                            <option value="İptal Edildi">🔴 İptal Edildi</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                                <a href="/Admin/AdminReservation/Index" class="btn btn-outline-secondary px-4">
                                    <i class="fas fa-arrow-left me-1"></i> Vazgeç
                                </a>
                                <button type="submit" class="btn btn-primary px-5 shadow-sm">
                                    <i class="fas fa-save me-1"></i> Değişiklikleri Kaydet
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-label {
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 0.6rem 1rem;
    }

    .card {
        border-radius: 12px;
    }

    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>
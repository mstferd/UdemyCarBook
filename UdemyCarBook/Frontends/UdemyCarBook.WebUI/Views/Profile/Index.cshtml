@model UserViewModel
@{
    ViewData["Title"] = "Profilim";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var rentals = (ViewBag.Rentals as List<UserRentalViewModel>) ?? new List<UserRentalViewModel>();
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f4f7f6;
    }

    .profile-card {
        transition: transform 0.3s;
    }

        .profile-card:hover {
            transform: translateY(-5px);
        }

    .rental-table thead th {
        background-color: #f8f9fa;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 1px;
        color: #888;
        border: none;
    }

    .rental-row {
        transition: background 0.2s;
    }

        .rental-row:hover {
            background-color: #fcfcfc;
        }

    .location-dot {
        color: #f8b739;
        font-size: 10px;
        margin-right: 5px;
    }

    .status-badge {
        font-weight: 600;
        font-size: 12px;
        letter-spacing: 0.5px;
        border-radius: 6px;
    }

    .car-info-box {
        background: #fff9f0;
        padding: 8px 12px;
        border-radius: 8px;
        border-left: 4px solid #f8b739;
    }

    .avatar-selection img {
        width: 85px;
        height: 85px;
        cursor: pointer;
        border-radius: 50%;
        margin: 12px;
        border: 4px solid transparent;
        transition: all 0.3s ease-in-out;
        object-fit: cover;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

        .avatar-selection img:hover {
            transform: scale(1.2);
            border-color: #f8b739;
        }

        .avatar-selection img.selected {
            border-color: #f8b739;
            box-shadow: 0 0 20px rgba(248, 183, 57, 0.7);
            transform: scale(1.1);
        }

    .avatar-wrapper {
        max-height: 250px;
        overflow-y: auto;
        padding: 20px;
        background: #fdfdfd;
        border-radius: 20px;
        border: 1px solid #eee;
    }
</style>

<div class="container-fluid px-lg-5 mt-5">
    <div class="row">
        <div class="col-lg-3 mb-4">
            <div class="card profile-card shadow-sm border-0 p-4" style="border-radius: 20px; background-color: #ffffff;">
                <div class="text-center">
                    <div class="position-relative d-inline-block">
                        <div class="rounded-circle shadow-sm" style="width: 120px; height: 120px; overflow: hidden; border: 3px solid #f8b739; padding: 3px;">
                            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/avatar1.png" : Model.ImageUrl)?v=@DateTime.Now.Ticks"
                                 style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                        </div>
                    </div>
                    <h5 class="font-weight-bold mt-3 mb-1">@Model.Name @Model.Surname</h5>
                    <p class="text-muted small">@@@Model.UserName</p>
                </div>

                <div class="mt-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-light p-2 rounded mr-3"><i class="fa fa-envelope text-warning"></i></div>
                        <div>
                            <small class="text-muted d-block">E-posta Adresi</small>
                            <span class="font-weight-600" style="font-size: 13px;">@Model.Email</span>
                        </div>
                    </div>
                </div>

                <a href="/Profile/EditProfile/@Model.AppUserId" class="btn btn-warning btn-block mt-4 text-white font-weight-bold shadow-sm" style="border-radius: 12px; height: 45px; display: flex; align-items: center; justify-content: center;">
                    <i class="fa fa-edit mr-2"></i> Profili Düzenle
                </a>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="card shadow-sm border-0 p-4" style="border-radius: 20px; background-color: #ffffff;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="font-weight-bold mb-0">
                        <i class="fa fa-clock text-warning mr-2"></i> Kiralama Geçmişim
                    </h4>
                    <span class="badge badge-light p-2 text-muted">Toplam: @rentals.Count Kayıt</span>
                </div>

                <div class="table-responsive">
                    <table class="table rental-table">
                        <thead>
                            <tr>
                                <th style="width: 25%">Araç Bilgisi</th>
                                <th style="width: 30%">Alış Noktası</th>
                                <th style="width: 30%">İade Noktası</th>
                                <th class="text-center" style="width: 15%">Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (rentals != null && rentals.Any())
                            {
                                foreach (var item in rentals)
                                {
                                    <tr class="rental-row">
                                        <td class="align-middle">
                                            <div class="car-info-box">
                                                <span class="d-block font-weight-bold text-dark" style="font-size: 14px;">@item.CarBrand</span>
                                                <span class="text-muted small">@item.CarModel</span>
                                            </div>
                                        </td>
                                        <td class="align-middle">
                                            <div>
                                                <i class="fa fa-map-marker-alt location-dot"></i>
                                                <span class="font-weight-bold d-block" style="font-size: 13px;">@item.PickUpLocationName</span>
                                                <small class="text-muted"><i class="far fa-clock mr-1"></i> @item.PickUpDate.ToString("dd MMM yyyy, HH:mm")</small>
                                            </div>
                                        </td>
                                        <td class="align-middle">
                                            <div>
                                                <i class="fa fa-flag-checkered location-dot"></i>
                                                <span class="font-weight-bold d-block" style="font-size: 13px;">@item.DropOffLocationName</span>
                                                <small class="text-muted"><i class="far fa-clock mr-1"></i> @item.DropOffDate.ToString("dd MMM yyyy, HH:mm")</small>
                                            </div>
                                        </td>
                                        <td class="text-center align-middle">
                                            @{
                                                var (badgeClass, icon) = item.Status switch
                                                {
                                                    "Onaylandı" => ("badge-success", "check-circle"),
                                                    "Rezervasyon Alındı" => ("badge-info", "info-circle"),
                                                    "İptal Edildi" => ("badge-danger", "times-circle"),
                                                    _ => ("badge-secondary", "question-circle")
                                                };
                                            }
                                            <span class="badge @badgeClass status-badge p-2 w-100 shadow-sm">
                                                <i class="fa fa-@icon mr-1"></i> @item.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5">
                                        <i class="fa fa-folder-open fa-3x mb-3 d-block text-light" style="opacity: 0.5;"></i>
                                        <p class="text-muted">Henüz bir araç kiralama geçmişiniz bulunmuyor.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

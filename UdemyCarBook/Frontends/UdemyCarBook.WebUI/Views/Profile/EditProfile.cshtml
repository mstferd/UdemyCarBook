@model UserViewModel
@{
    ViewData["Title"] = "Profili Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-9">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div style="height: 8px; background: #ffc107;"></div>

                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-5">
                        <h2 class="fw-bold text-dark">Profil Ayarları</h2>
                        <p class="text-muted">Tüm profil bilgilerinizi buradan güncelleyebilirsiniz.</p>
                    </div>

                    <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="AppUserId" />
                        <input type="hidden" asp-for="ImageUrl" id="ImageUrlHidden" />

                        <div class="row">
                            <div class="col-lg-4 border-end-lg text-center mb-4 mb-lg-0">
                                <h5 class="fw-bold mb-4 text-secondary text-uppercase small">Profil Fotoğrafı</h5>
                                <div class="avatar-main-wrapper mb-4">
                                    <div class="avatar-preview-box shadow-sm">
                                        <img id="previewImage" src="@(Model.ImageUrl ?? "/images/avatar1.png")" alt="Profil" />
                                    </div>
                                </div>
                                <div class="upload-section p-3 bg-light rounded-4 border border-dashed">
                                    <label class="form-label fw-bold text-dark d-block small">Kendi Fotoğrafını Yükle</label>
                                    <input type="file" name="ImageFile" class="form-control form-control-sm" accept="image/*" onchange="previewFile(event)" />
                                </div>
                            </div>

                            <div class="col-lg-8 ps-lg-5">
                                <h5 class="fw-bold mb-4 text-secondary text-uppercase small">Kişisel ve Hesap Bilgileri</h5>

                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-dark small">Adınız</label>
                                        <input asp-for="Name" class="form-control shadow-sm" placeholder="Adınızı girin" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-dark small">Soyadınız</label>
                                        <input asp-for="Surname" class="form-control shadow-sm" placeholder="Soyadınızı girin" />
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label fw-bold text-dark small">Gmail / E-posta Adresi</label>
                                        <div class="input-group shadow-sm">
                                            <span class="input-group-text bg-white"><i class="fa fa-envelope text-warning"></i></span>
                                            <input asp-for="Email" type="email" class="form-control border-start-0" placeholder="ornek@gmail.com" />
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-dark small">Kullanıcı Adı</label>
                                        <div class="input-group shadow-sm">
                                            <span class="input-group-text bg-white"><i class="fa fa-user text-warning"></i></span>
                                            <input asp-for="UserName" class="form-control border-start-0" placeholder="kullanıcıadı" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold text-dark small">Yeni Şifre</label>
                                        <div class="input-group shadow-sm">
                                            <span class="input-group-text bg-white"><i class="fa fa-key text-warning"></i></span>
                                            <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="••••••" />
                                        </div>
                                    </div>
                                </div>

                                <h5 class="fw-bold mb-3 text-secondary text-uppercase small">Hızlı Avatar Seç</h5>
                                <div class="avatar-selection-grid mb-5 shadow-sm">
                                    @for (int i = 1; i <= 8; i++)
                                    {
                                        <div class="avatar-option-item">
                                            <img src="/images/avatar@(i).png" onclick="setAvatar(this)"
                                                 class="avatar-img @(Model.ImageUrl == $"/images/avatar{i}.png" ? "active" : "")" />
                                        </div>
                                    }
                                </div>

                                <div class="d-flex gap-3">
                                    <button type="submit" class="btn btn-warning flex-grow-1 btn-lg text-white fw-bold shadow py-3">
                                        <i class="fa fa-save me-2"></i> <br />Değişiklikleri Kaydet
                                    </button>
                                    <a href="/Profile/Index" class="btn btn-outline-secondary btn-lg px-4">İptal</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
        border-color: #ffc107 !important;
    }

    .avatar-preview-box {
        width: 180px;
        height: 180px;
        border-radius: 50%;
        overflow: hidden;
        display: inline-block;
        border: 6px solid #fff;
        box-shadow: 0 8px 15px rgba(0,0,0,0.1);
    }

        .avatar-preview-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Avatar Boyutlarını Buradan Büyütebilirsin */
    .avatar-selection-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(90px, 1fr));
        gap: 12px;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 1rem;
    }

    .avatar-img {
        width: 85px;
        height: 85px;
        cursor: pointer;
        border-radius: 50%;
        transition: 0.3s;
        border: 3px solid transparent;
        background: #fff;
        object-fit: cover;
    }

        .avatar-img:hover {
            transform: scale(1.1);
            border-color: #ffc107;
        }

        .avatar-img.active {
            border-color: #ffc107;
            box-shadow: 0 0 10px rgba(255,193,7,0.5);
        }

    .input-group-text {
        border-right: none;
    }

    .form-control:focus {
        border-color: #ffc107;
        box-shadow: none;
    }

    @@media (min-width: 992px) {
        .border-end-lg {
            border-right: 1px solid #eee !important;
        }
    }
</style>

<script>
    function setAvatar(img) {
        const src = img.getAttribute("src");
        document.getElementById("previewImage").src = src;
        document.getElementById("ImageUrlHidden").value = src;
        document.querySelectorAll('.avatar-img').forEach(el => el.classList.remove('active'));
        img.classList.add('active');
    }

    function previewFile(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function() {
                document.getElementById("previewImage").src = reader.result;
                document.getElementById("ImageUrlHidden").value = "";
                document.querySelectorAll('.avatar-img').forEach(el => el.classList.remove('active'));
            }
            reader.readAsDataURL(file);
        }
    }
</script>
@{
	ViewData["Title"] = "CarDetail";
	Layout = "~/Views/ULayout/Index.cshtml";
}

<section class="ftco-section ftco-car-details">
	<div class="container">

		@await Component.InvokeAsync("_CarDetailMainCarFeatureComponentPartial", new { id = ViewBag.carid })

		<div class="row mb-5 mt-4">
			<div class="col-md-12">
				<div style="background: #ffffff; padding: 20px 40px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); display: flex; justify-content: space-between; align-items: center; border-left: 5px solid #ff9800;">
					<div>
						<h5 style="margin: 0; font-weight: 700; color: #2c3e50;">Bu Aracı Beğendiniz mi?</h5>
						<p style="margin: 0; font-size: 13px; color: #7f8c8d;">En uygun fiyat garantisiyle hemen rezervasyonunuzu oluşturun.</p>
					</div>
					<a href="/Reservation/Index/@ViewBag.carid"
					   style="background: #ff9800; color: #fff; padding: 12px 30px; border-radius: 8px; font-weight: 700; text-transform: uppercase; text-decoration: none; transition: 0.3s; box-shadow: 0 4px 15px rgba(255, 152, 0, 0.3);">
						Şimdi Rezerve Et <i class="fas fa-chevron-right ml-2"></i>
					</a>
				</div>
			</div>
		</div>

		<div class="row">
			<div class="col-md-12 pills">
				<div class="bd-example bd-example-tabs">

					@await Component.InvokeAsync("_CarDetailTabPaneComponentPartial")

					<div class="tab-content" id="pills-tabContent">
						@await Component.InvokeAsync("_CarDetailCarFeatureByCarIdComponentPartial", new { id = ViewBag.carid })
						@await Component.InvokeAsync("_CarDetailCarDescriptionByCarIdComponentPartial", new { id = ViewBag.carid })
						@await Component.InvokeAsync("_CarDetailCommentsByCarIdComponentPartial", new { id = ViewBag.carid })
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
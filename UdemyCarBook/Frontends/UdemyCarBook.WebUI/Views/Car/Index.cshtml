<style>
    /* Daha Premium Bir Turuncu */
    :root {
        --main-orange: #ff9f1c;
        --dark-blue: #2c3e50;
    }

    /* Ana Buton: Dolu Turuncu */
    .btn-theme-primary {
        background-color: var(--main-orange) !important;
        border: none !important;
        color: #fff !important;
        font-weight: 600;
        border-radius: 5px;
        transition: 0.3s;
    }

        .btn-theme-primary:hover {
            background-color: #e68a00 !important;
            box-shadow: 0 4px 15px rgba(255, 159, 28, 0.3);
        }

    /* İkincil Buton: Şık ve Sade */
    .btn-theme-outline {
        background-color: #f8f9fa !important;
        border: 1px solid #ddd !important;
        color: #666 !important;
        font-weight: 600;
        border-radius: 5px;
    }

        .btn-theme-outline:hover {
            background-color: var(--dark-blue) !important;
            color: #fff !important;
            border-color: var(--dark-blue) !important;
        }

    /* Fiyat Alanı: Turuncu kalsın ama daha zarif olsun */
    .theme-orange {
        color: var(--main-orange) !important;
        font-weight: 800 !important;
        font-size: 1.1rem;
    }

    /* Marka ismini biraz belirginleştir */
    .cat {
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 11px;
        color: #b0b0b0;
    }
</style>
@model List<ResultCarPricingWithCarDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/ULayout/Index.cshtml";
}
<section class="ftco-section bg-light">
    <div class="container">
        <div class="row">
            @foreach(var item in Model)
            {
                <div class="col-md-4">
                    <div class="car-wrap rounded ftco-animate">
                        <div class="img rounded d-flex align-items-end" style="background-image: url(@item.CoverImageUrl);">
                        </div>
                        <div class="text">
                            <h2 class="mb-0"><a href="car-single.html">@item.Model</a></h2>
                            <div class="d-flex mb-3">
                                <span class="cat">@item.Brand</span>
                                <p class="price ml-auto theme-orange">@item.Amount ₺ <span>/Günlük</span></p>
                            </div>
                            <p class="d-flex mb-0 d-block">
                                @if (User.Identity.IsAuthenticated)
                                {
                                    @* Giriş yapmışsa direkt rezervasyona *@
                                    <a href="/Reservation/CreateReservation/@item.CarId" class="btn btn-theme-primary py-2 mr-1">Hemen Kirala</a>
                                }
                                else
                                {
                                    @* Giriş yapmamışsa Layout'ta yazdığımız fonksiyonu tetikle *@
                                    <a href="javascript:void(0);" onclick="showLoginWarning()" class="btn btn-theme-primary py-2 mr-1">Hemen Kirala</a>
                                }

                                <a href="/Car/CarDetail/@item.CarId" class="btn btn-theme-outline py-2 ml-1">Detaylar</a>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>       
    </div>
</section>
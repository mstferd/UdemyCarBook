@model List<UdemyCarBook.Dto.ReservationDtos.ResultReservationDto>
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h4 class="card-title m-0 text-dark" style="font-weight: 700;">
                        <i class="fas fa-clock text-primary me-2"></i> Rezervasyon ve Zaman Yönetimi
                    </h4>
                    <span class="badge rounded-pill bg-soft-primary text-primary px-3 py-2">
                        Toplam @Model?.Count Kayıt
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted font-size-12 text-uppercase">
                            <tr>
                                <th class="border-0">Müşteri Ad - Soyad </th>
                                <th class="border-0">E-posta</th>
                                <th class="border-0">Telefon</th>
                                <th class="border-0">Alış Bilgileri</th>
                                <th class="border-0">Dönüş Bilgileri</th>
                                <th class="border-0">Araç</th>
                                <th class="border-0">Durum</th>
                                <th class="border-0 text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-5 text-muted">Görüntülenecek rezervasyon bulunamadı.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-bold text-dark">@item.Name @item.Surname</td>
                                        <td><span class="text-muted font-size-13">@item.Email</span></td>
                                        <td><span class="text-muted font-size-13">@item.Phone</span></td>
                                        <td>
                                            <div class="font-size-13">
                                                <span class="text-success d-block fw-medium">@item.PickUpLocationName</span>
                                                <small class="text-muted">@item.PickUpFull.ToString("dd.MM.yyyy HH:mm")</small>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="font-size-13">
                                                <span class="text-danger d-block fw-medium">@item.DropOffLocationName</span>
                                                <small class="text-muted">@item.DropOffFull.ToString("dd.MM.yyyy HH:mm")</small>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-light text-secondary border">@item.CarName</span></td>
                                        <td>
                                            @{
                                                string sClass = item.Status == "İptal Edildi" ? "bg-soft-danger text-danger" :
                                                item.Status == "Onaylandı" ? "bg-soft-success text-success" : "bg-soft-warning text-warning";
                                            }
                                            <span class="badge @sClass px-2 py-1" style="font-size: 11px;">@item.Status</span>
                                        </td>
                                        <td class="text-center">

                                            <div class="d-flex justify-content-center gap-1">
                                                @* Onayla *@
                                                <a href="/Reservation/ApproveReservation/@item.ReservationID" class="btn btn-sm btn-soft-success">
                                                    <i class="fas fa-check"></i>
                                                </a>
                                                @* düzenle *@
                                                <a href="/Reservation/EditReservation/@item.ReservationID" class="btn btn-sm btn-soft-primary">
                                                    <i class="fas fa-pen"></i>
                                                </a>

                                                @* İptal *@
                                                <a href="/Reservation/CancelReservation/@item.ReservationID" class="btn btn-sm btn-soft-danger">
                                                    <i class="fas fa-times"></i>
                                                </a>
                                            </div>
                                        </td>
                                    
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-sm {
        padding: 0.25rem 0.5rem;
    }

    .btn-soft-success {
        color: #34c38f;
        background-color: rgba(52, 195, 143, 0.1);
        border: none;
    }

    .btn-soft-primary {
        color: #556ee6;
        background-color: rgba(85, 110, 230, 0.1);
        border: none;
    }

    .btn-soft-danger {
        color: #f46a6a;
        background-color: rgba(244, 106, 106, 0.1);
        border: none;
    }

    .bg-soft-primary {
        background-color: rgba(85, 110, 230, 0.1);
    }

    .bg-soft-success {
        background-color: rgba(52, 195, 143, 0.1);
    }

    .bg-soft-danger {
        background-color: rgba(244, 106, 106, 0.1);
    }

    .bg-soft-warning {
        background-color: rgba(241, 180, 76, 0.1);
    }
</style>
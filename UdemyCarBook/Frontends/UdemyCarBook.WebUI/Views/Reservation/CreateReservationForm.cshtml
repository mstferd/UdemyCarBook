@model CreateReservationDto
@{
    ViewData["Title"] = "Araç Rezervasyon Formu";
    Layout = "~/Views/ULayout/Index.cshtml";
}
<style>
    .reservation-form input,
    .reservation-form select,
    .reservation-form textarea {
        border-radius: 10px;
        border: 1px solid #dee2e6;
    }

        .reservation-form input:focus,
        .reservation-form select:focus,
        .reservation-form textarea:focus {
            border-color: #2f89fc;
            box-shadow: 0 0 0 0.1rem rgba(47,137,252,.25);
        }

    .reservation-form {
        max-width: 800px;
        margin: 50px auto;
    }

    /* Şık uyarı kutusu stilleri */
    #availability-alert {
        transition: all 0.3s ease;
    }
</style>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-warning shadow-sm border-0 mb-4 p-4" role="alert" style="border-left: 5px solid #ffc107 !important;">
        <div class="d-flex align-items-center">
            <i class="fa fa-calendar-check fa-2x text-warning me-3"></i>
            <div>
                <h5 class="alert-heading fw-bold">Araç Bu Tarihlerde Dolu!</h5>
                <p class="mb-0">@ViewBag.ErrorMessage</p>
            </div>
        </div>
    </div>
}


<form class="reservation-form shadow-lg p-5 rounded bg-white" method="post" asp-action="CreateReservation" asp-controller="Reservation">
    <h4 class="text-center mb-4 font-weight-bold" style="color:#2f89fc;">
        Araç Rezervasyon Formu
    </h4>

    <input type="hidden" asp-for="CarID" id="CarID" />
    <input type="hidden" asp-for="Status" value="Rezervasyon Alındı" />
    <input type="hidden" asp-for="AppUserId" value="@User.Claims.FirstOrDefault(x => x.Type == "Id" || x.Type == "id")?.Value" />

    <div class="form-group">
        <label class="font-weight-bold">Seçilen Araç</label>
        @Html.DropDownListFor(x => x.CarID, (List<SelectListItem>)ViewBag.CarList, new {
        @class = "form-control",
                @style = "background-color: #f1f3f5; pointer-events: none;"
                })
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">Adınız</label>
                <input type="text" asp-for="Name" class="form-control"
                       value="@(Model.Name ?? User.Claims.FirstOrDefault(x => x.Type == "Name")?.Value)"
                       placeholder="Adınızı giriniz" required>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">Soyadınız</label>
                <input type="text" asp-for="Surname" class="form-control"
                       value="@(Model.Surname ?? User.Claims.FirstOrDefault(x => x.Type == "Surname")?.Value)"
                       placeholder="Soyadınızı giriniz" required>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">Alış Tarihi ve Saati</label>
                <input type="datetime-local" class="form-control" asp-for="PickUpDate" id="PickUpDate"
                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                       max="@DateTime.Now.AddMonths(1).ToString("yyyy-MM-ddTHH:mm")"
                       value="@(Model.PickUpDate != DateTime.MinValue ? Model.PickUpDate.ToString("yyyy-MM-ddTHH:mm") : DateTime.Now.ToString("yyyy-MM-ddTHH:mm"))">
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">İade Tarihi ve Saati</label>
                <input type="datetime-local" class="form-control" asp-for="DropOffDate" id="DropOffDate"
                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                       max="@DateTime.Now.AddMonths(1).ToString("yyyy-MM-ddTHH:mm")"
                       value="@(Model.DropOffDate != DateTime.MinValue ? Model.DropOffDate.ToString("yyyy-MM-ddTHH:mm") : DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm"))">
            </div>
        </div>
    </div>

    <div id="availability-alert" class="mt-2 mb-4 shadow-sm p-3 rounded-3 d-none">
        <div class="d-flex align-items-center">
            <i id="alert-icon" class="fa fa-2x me-3"></i>
            <div>
                <h6 id="alert-title" class="fw-bold mb-1"></h6>
                <p id="alert-text" class="small mb-0"></p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">Email</label>
                <input type="email" asp-for="Email" class="form-control"
                       value="@(Model.Email ?? User.Claims.FirstOrDefault(x => x.Type == "Email")?.Value)" required>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">Telefon</label>
                <input type="text" asp-for="Phone" class="form-control" placeholder="05xx xxx xx xx" required>
            </div>
        </div>
    </div>

    <div class="form-group">
        <label class="font-weight-bold">Alış Lokasyonu</label>
        @Html.DropDownListFor(x => x.PickUpLocationID,
                new SelectList((IEnumerable<SelectListItem>)ViewBag.LocationList, "Value", "Text", Model.PickUpLocationID.ToString()),
                "Lütfen Alış Lokasyonu Seçiniz",
                new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label class="font-weight-bold">İade Lokasyonu</label>
        @Html.DropDownListFor(x => x.DropOffLocationID,
                new SelectList((IEnumerable<SelectListItem>)ViewBag.LocationList, "Value", "Text", Model.DropOffLocationID > 0 ? Model.DropOffLocationID.ToString() : ""),
                "Lütfen İade Lokasyonu Seçiniz",
                new { @class = "form-control" })
    </div>
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">Yaş</label>
                <input type="number" asp-for="Age" class="form-control"
                       value="@(Model.Age > 0 ? Model.Age.ToString() : "")"
                       placeholder="Yaşınız" required min="18">
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">Ehliyet Numarası</label>
                <input type="text" asp-for="DriverLicenseNumber" class="form-control"
                       placeholder="Ehliyet Numarası Giriniz" required>
            </div>
        </div>
    </div>

    <div class="form-group">
        <label class="font-weight-bold">Ek Açıklama</label>
        <textarea asp-for="Description" rows="4" class="form-control"
                  placeholder="Varsa eklemek istedikleriniz..."></textarea>
    </div>

    <div class="text-center mt-4">
        <button type="submit" id="btnSubmit" class="btn btn-primary px-5 py-3" style="border-radius:30px; font-weight:600;">
            Rezervasyonu Tamamla
        </button>
    </div>
</form>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // Anlık Tarih Kontrolü ve Kısıtlamalar
    $(document).ready(function () {
        const pickupInput = $('#PickUpDate');
        const dropoffInput = $('#DropOffDate');
        const carId = $('#CarID').val();

        // 1. Tarih Sınırlarını Belirleme (Bugün ve 1 Ay Sonrası)
        const now = new Date();
        const oneMonthLater = new Date();
        oneMonthLater.setMonth(now.getMonth() + 1);

        // Tarihi inputun anlayacağı formatta (yyyy-MM-ddTHH:mm) hazırlayan yardımcı fonksiyon
        function formatDateTime(date) {
            const tzoffset = date.getTimezoneOffset() * 60000;
            return (new Date(date - tzoffset)).toISOString().slice(0, 16);
        }

        const minDate = formatDateTime(now);
        const maxDate = formatDateTime(oneMonthLater);

        // Inputlara sınırları uygula
        pickupInput.attr('min', minDate);
        pickupInput.attr('max', maxDate);
        dropoffInput.attr('min', minDate);
        dropoffInput.attr('max', maxDate);

        function checkAvailability() {
            const pickup = pickupInput.val();
            const dropoff = dropoffInput.val();

            if (pickup && dropoff) {
                $.get(`/Reservation/CheckCarAvailability`, { carId: carId, pickup: pickup, dropoff: dropoff }, function (res) {
                    const alertDiv = $('#availability-alert');
                    const btn = $('#btnSubmit');

                    alertDiv.removeClass('d-none alert-success alert-warning alert-danger');

                    if (res.available) {
                        alertDiv.addClass('alert-success').css('border-left', '5px solid #198754');
                        $('#alert-icon').attr('class', 'fa fa-check-circle text-success me-3');
                        $('#alert-title').text('Araç Müsait');
                        $('#alert-text').text('Seçtiğiniz tarihlerde kiralama yapabilirsiniz.');
                        btn.prop('disabled', false).css('opacity', '1').text('Rezervasyonu Tamamla');
                    } else {
                        alertDiv.addClass('alert-warning').css('border-left', '5px solid #ffc107');
                        $('#alert-icon').attr('class', 'fa fa-exclamation-triangle text-warning me-3');
                        $('#alert-title').text('Tarihler Uygun Değil');

                        let cleanMessage = res.message;
                        try {
                            const jsonMsg = JSON.parse(res.message);
                            cleanMessage = jsonMsg.message || "Seçilen tarihlerde araç maalesef dolu.";
                        } catch (e) {
                            if (cleanMessage.includes("validation errors")) {
                                cleanMessage = "Seçilen tarih formatı veya veriler uygun değil.";
                            }
                        }
                        $('#alert-text').text(cleanMessage);
                        btn.prop('disabled', true).css('opacity', '0.6').text('Araç Dolu');
                    }
                });
            }
        }

        // Alış tarihi değiştiğinde iade tarihinin alt sınırını güncelle
        pickupInput.on('change', function() {
            const pickupVal = $(this).val();
            if(pickupVal) {
                dropoffInput.attr('min', pickupVal); // İade en erken alış tarihinde olabilir

                // Eğer mevcut iade tarihi yeni seçilen alış tarihinden önceyse, iadeyi temizle/güncelle
                if(dropoffInput.val() < pickupVal) {
                    dropoffInput.val(pickupVal);
                }
            }
            checkAvailability();
        });

        dropoffInput.on('change', checkAvailability);
    });

    // Form Gönderim SweetAlert
    document.querySelector('.reservation-form').addEventListener('submit', function (e) {
        const btn = document.getElementById('btnSubmit');
        if(btn.disabled) return;

        e.preventDefault();
        const form = this;

        Swal.fire({
            title: 'Rezervasyonunuz Alındı!',
            text: 'Rezervasyon talebiniz başarıyla bize ulaştı.',
            icon: 'success',
            confirmButtonText: 'Tamam',
            confirmButtonColor: '#2f89fc'
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
    });
</script>
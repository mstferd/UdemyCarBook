@model List<ResultAllBlogsWithAuthorDto>
@{
    ViewData["Title"] = "Bloglar";
    Layout = "~/Views/ULayout/Index.cshtml";
}

<style>
    /* BookCar Açık Tema Modern Blog Tasarımı */
    .blog-section {
        background-color: #f8f9fa; /* Diğer sayfalarla uyumlu hafif gri/beyaz arka plan */
        padding: 80px 0;
    }

    .blog-card {
        background: #ffffff;
        border-radius: 15px;
        border: none;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05); /* Yumuşak gölge */
        overflow: hidden;
        transition: all 0.3s ease-in-out;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .blog-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        }

    .blog-img {
        height: 220px;
        background-size: cover;
        background-position: center;
        position: relative;
    }

    .blog-content {
        padding: 25px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .blog-category {
        color: #ff9800; /* Turuncu vurgu rengi */
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 10px;
        display: block;
    }

    .blog-title {
        font-size: 19px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 15px;
        line-height: 1.4;
    }

        .blog-title a {
            color: inherit;
            text-decoration: none;
            transition: 0.2s;
        }

            .blog-title a:hover {
                color: #ff9800;
            }

    .blog-description {
        color: #7f8c8d;
        font-size: 14px;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .blog-meta {
        border-top: 1px solid #eee;
        padding-top: 15px;
        margin-top: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: #95a5a6;
    }

    /* Görsellerdeki turuncu buton stiliyle uyumlu */
    .btn-read-more {
        background-color: #ff9800;
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 5px;
        font-weight: 600;
        font-size: 14px;
        transition: 0.3s;
    }

        .btn-read-more:hover {
            background-color: #e68a00;
            color: white;
            box-shadow: 0 4px 12px rgba(255, 152, 0, 0.3);
        }

    .section-header h2 {
        font-weight: 800;
        color: #2c3e50;
        position: relative;
        padding-bottom: 15px;
    }

        .section-header h2::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 3px;
            background: #ff9800;
        }
</style>

<section class="blog-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center section-header">
                <h2 class="mb-3">Blog Dünyamız</h2>
                <p class="text-muted">En güncel araç incelemeleri ve seyahat rotaları burada.</p>
            </div>
        </div>

        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4 d-flex">
                    <div class="blog-card">
                        <a href="/Blog/BlogDetail/@item.blogID" class="blog-img" style="background-image: url('@item.coverImageUrl');">
                        </a>
                        <div class="blog-content">
                            <span class="blog-category">Araç Dünyası</span>
                            <h3 class="blog-title">
                                <a href="/Blog/BlogDetail/@item.blogID">@item.title</a>
                            </h3>
                            <p class="blog-description">
                                @(item.Description?.Length > 110 ? item.Description.Substring(0, 110) + "..." : item.Description)
                            </p>
                            <div class="blog-meta">
                                <span><i class="far fa-user mr-1"></i> @item.authorName</span>
                                <span><i class="far fa-calendar-alt mr-1"></i> @item.createdDate.ToString("dd MMM yyyy")</span>
                            </div>
                            <div class="mt-3">
                                <a href="/Blog/BlogDetail/@item.blogID" class="btn-read-more w-100 text-center">
                                    Devamını Oku
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
@model UdemyCarBook.Dto.RegisterDto.CreateRegisterDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>CarBook - Yeni Üyelik</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="shortcut icon" href="~/Admin/vertical/assets/images/favicon.ico">
    <link href="~/Admin/vertical/assets/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Admin/vertical/assets/css/icons.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Admin/vertical/assets/css/theme.min.css" rel="stylesheet" type="text/css" />
    <style>
        .bg-register {
            background-image: url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&q=80&w=1000');
            background-size: cover;
            background-position: center;
        }

        .btn-custom {
            background-color: #ff9f1c;
            border: none;
            color: white;
            font-weight: bold;
            padding: 12px;
        }

            .btn-custom:hover {
                background-color: #e68a00;
                color: white;
            }
    </style>
</head>

<body>
    <div>
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex align-items-center min-vh-100">
                        <div class="w-100 d-block bg-white shadow-lg rounded my-5">
                            <div class="row">
                                <div class="col-lg-5 d-none d-lg-block bg-register rounded-left"></div>
                                <div class="col-lg-7">
                                    <div class="p-5">
                                        <div class="text-center mb-5">
                                            <a href="/Default/Index/" class="text-dark font-size-22">
                                                <i class="mdi mdi-car-sports text-warning"></i> <b>Car<span>Book</span></b>
                                            </a>
                                        </div>
                                        <h1 class="h5 mb-1">Aramıza Katıl!</h1>
                                        <p class="text-muted mb-4">Hemen üye ol ve hayalindeki aracı kiralamaya baş.</p>

                                        <form class="user" method="post">
                                            @* Ad ve Soyad Yan Yana *@
                                            <div class="form-group row">
                                                <div class="col-sm-6 mb-3 mb-sm-0">
                                                    <input type="text" class="form-control" placeholder="Adınız" asp-for="Name" required>
                                                </div>
                                                <div class="col-sm-6">
                                                    <input type="text" class="form-control" placeholder="Soyadınız" asp-for="Surname" required>
                                                </div>
                                            </div>

                                            @* Kullanıcı Adı *@
                                            <div class="form-group">
                                                <input type="text" class="form-control" placeholder="Kullanıcı Adınız" asp-for="Username" required>
                                            </div>

                                            @* E-posta *@
                                            <div class="form-group">
                                                <input type="email" class="form-control" placeholder="E-posta Adresiniz" asp-for="Email" required>
                                            </div>

                                            @* Şifre *@
                                            <div class="form-group">
                                                <input type="password" class="form-control" placeholder="Şifreniz" asp-for="Password" required>
                                            </div>

                                            <button type="submit" class="btn btn-custom btn-block waves-effect waves-light shadow-sm">
                                                Kayıt Ol <i class="mdi mdi-account-plus ml-1"></i>
                                            </button>
                                        </form>

                                        <div class="row mt-4">
                                            <div class="col-12 text-center">
                                                <p class="text-muted mb-0">
                                                    Zaten bir hesabın var mı?
                                                    <a href="/Login/Index/" class="text-warning font-weight-bold ml-1">Giriş Yap</a>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/Admin/vertical/assets/js/jquery.min.js"></script>
    <script src="~/Admin/vertical/assets/js/bootstrap.bundle.min.js"></script>
</body>
</html>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

@section Scripts
{
    <div class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <script type="text/javascript">
                            $(document).ready(() => {
                                var connection = new signalR.HubConnectionBuilder().withUrl("https://localhost:7125/CarHub").build();
                                $("#constatus").text(connection.state);//durumu gösteririr con. durumunu gösteriri bağlantı durumu evet / hayır
                                connection.start().then(() => {
                                    $("#constatus").text(connection.state);//bağlantı gerçekleştirir ise bağlantı durumunu text olarak yazdırır
                                    setInterval(() => {
                                        connection.invoke("SendCarCount");//hata olursa çalışır
                                    }, 1000);//kaç saniyedwe sayfa yenilensin
                                }).catch((err) => { console.log(err) });

                                connection.on("ReceiveCarCount", (value) => {
                                    $("#carcount").text(value);
                                });
                            });
                        </script>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row">
    <div class="col-md-8 offset-2">
        <div class="alert alert-info">Bağlantının Durumu: <strong id="constatus"></strong></div> 
    </div>
    <div class="col-md-8 offset-2">
        <div class="alert alert-danger">Araba Sayısı: <strong id="carcount"></strong></div>
    </div>
</div>
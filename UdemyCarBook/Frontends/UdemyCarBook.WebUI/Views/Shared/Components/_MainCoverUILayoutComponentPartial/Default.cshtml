@* style kısmındaki url içeriğini @ViewBag.v3 olarak güncelledik *@
<section class="hero-wrap hero-wrap-2 js-fullheight"
         style="background-image: url('@(ViewBag.v3 ?? "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070&auto=format&fit=crop")');"
         data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text js-fullheight align-items-end justify-content-start">
            <div class="col-md-9 ftco-animate pb-5">
                <p class="breadcrumbs">
                    <span class="mr-2">
                        <a href="/Default/Index/">AnaSayfa <i class="ion-ios-arrow-forward"></i></a>
                    </span>
                    <span>@ViewBag.v1 <i class="ion-ios-arrow-forward"></i></span>
                </p>
                <h1 class="mb-3 bread">@ViewBag.v2</h1>
            </div>
        </div>
    </div>
</section>
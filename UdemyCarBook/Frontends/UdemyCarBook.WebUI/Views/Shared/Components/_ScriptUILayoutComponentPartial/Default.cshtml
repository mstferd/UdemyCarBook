<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
    var map = L.map('map').setView([41.2753, 28.7519], 13);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    L.marker([41.2753, 28.7519])
        .addTo(map)
        .bindPopup("CarBook Rent A Car - İstanbul Havalimanı Ofisi")
        .openPopup();
</script>
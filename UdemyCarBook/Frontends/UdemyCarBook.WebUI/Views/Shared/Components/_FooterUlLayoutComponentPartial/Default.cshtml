@model List<ResultFooterAddressDto>

<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>

<style>
    /* Footer Genel Tasarımı */
    .ftco-footer-custom {
        background: #111111 !important; /* Saf siyah yerine çok koyu bir ton */
        padding: 80px 0 40px 0;
        font-family: 'Poppins', sans-serif;
    }

        .ftco-footer-custom .ftco-heading-2 {
            color: #ffffff;
            font-weight: 700;
            font-size: 20px;
            margin-bottom: 30px;
            position: relative;
        }

            /* Başlıkların altındaki turuncu çizgi */
            .ftco-footer-custom .ftco-heading-2::after {
                content: '';
                position: absolute;
                left: 0;
                bottom: -10px;
                width: 40px;
                height: 2px;
                background: #ff9f1c;
            }

        .ftco-footer-custom p, .ftco-footer-custom .block-23 ul li .text {
            color: rgba(255,255,255,0.6) !important;
            font-size: 15px;
        }

        /* Linklerin Hover Efekti */
        .ftco-footer-custom ul li a {
            color: rgba(255,255,255,0.7) !important;
            transition: all 0.3s ease;
            padding-left: 0;
        }

            .ftco-footer-custom ul li a:hover {
                color: #ff9f1c !important;
                padding-left: 10px;
                text-decoration: none;
            }

    /* Sosyal Medya İkonları */
    .ftco-footer-social li a {
        background: rgba(255,255,255,0.05) !important;
        color: #fff !important;
        border: 1px solid rgba(255,255,255,0.1);
        transition: 0.3s;
    }

        .ftco-footer-social li a:hover {
            background: #ff9f1c !important;
            color: #1c2731 !important;
            border-color: #ff9f1c !important;
        }

    /* İletişim İkonları */
    .block-23 ul li span.icon {
        color: #ff9f1c !important;
        font-size: 18px;
    }

    /* Alt Telif Hakları Alanı */
    .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.05);
        padding-top: 30px;
        margin-top: 50px;
    }

    /* SweetAlert Özelleştirme (Buton Rengi) */
    .swal-button {
        background-color: #ff9f1c;
        border: none;
        box-shadow: none;
    }

        .swal-button:not([disabled]):hover {
            background-color: #e68a00;
        }
</style>

<script>
    $(document).ready(function () {
        // SweetAlert pencerelerini daha kurumsal hale getirdik
        const showInfo = (title, text) => {
            swal({
                title: title,
                text: text,
                icon: "info",
                button: "Anladım",
            });
        };

        $('#btn1').click(function (e) { e.preventDefault(); showInfo("Şartlar & Koşullar", "Araba kiralama sürecine dair tüm hizmet koşullarına ofislerimizde yer alan anlaşma dokümanlarından ulaşabilirsiniz."); });
        $('#btn2').click(function (e) { e.preventDefault(); showInfo("Güvenlik", "Sistemimizde Sha256 şifreleme ve JWT doğrulaması yapılmaktadır. Kart bilgileriniz kesinlikle saklanmaz."); });
        $('#btn3').click(function (e) { e.preventDefault(); showInfo("Çerez Politikası", "Size daha iyi hizmet sunabilmek adına tarayıcı çerezlerini kullanmaktayız."); });
        $('#btn4').click(function (e) { e.preventDefault(); showInfo("Sıkça Sorulan Sorular", "Kiralama süreci, iptal iade ve ek hizmetlerle ilgili tüm sorularınız için destek ekibimize ulaşabilirsiniz."); });
        $('#btn5').click(function (e) { e.preventDefault(); showInfo("Ödeme Yöntemleri", "Ödemeler fiziki lokasyonlarımızda tüm banka ve kredi kartları ile gerçekleştirilebilmektedir."); });
        $('#btn6').click(function (e) { e.preventDefault(); showInfo("Nasıl Çalışır", "1. Aracını Seç \n2. Rezervasyonunu Yap \n3. Ofisimizden Teslim Al."); });
    });
</script>

@foreach (var item in Model)
{
    <footer class="ftco-footer ftco-footer-custom">
        <div class="container">
            <div class="row mb-5">
                <div class="col-md">
                    <div class="ftco-footer-widget mb-4">
                        <h2 class="ftco-heading-2">
                            <a href="#" class="logo" style="color: #fff; text-transform: uppercase; letter-spacing: 1px;">
                                CAR<span style="color: #ff9f1c;">BOOK</span>
                            </a>
                        </h2>
                        <p style="text-align: justify; padding-right: 20px;">@item.Description</p>
                        <ul class="ftco-footer-social list-unstyled float-md-left float-lft mt-4">
                            <li class="ftco-animate"><a href="#"><span class="icon-twitter"></span></a></li>
                            <li class="ftco-animate"><a href="#"><span class="icon-facebook"></span></a></li>
                            <li class="ftco-animate"><a href="#"><span class="icon-instagram"></span></a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-md">
                    <div class="ftco-footer-widget mb-4 ml-md-5">
                        <h2 class="ftco-heading-2">Kurumsal</h2>
                        <ul class="list-unstyled">
                            <li><a href="/About/Index/" class="py-2 d-block">Hakkımızda</a></li>
                            <li><a href="/Car/Index/" class="py-2 d-block">Hizmetlerimiz</a></li>
                            <li><a href="#" id="btn1" class="py-2 d-block">Şartlar & Koşullar</a></li>
                            <li><a href="#" id="btn2" class="py-2 d-block">Güvenlik</a></li>
                            <li><a href="#" id="btn3" class="py-2 d-block">Çerez Politikası</a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-md">
                    <div class="ftco-footer-widget mb-4">
                        <h2 class="ftco-heading-2">Müşteri Desteği</h2>
                        <ul class="list-unstyled">
                            <li><a href="#" id="btn4" class="py-2 d-block">Sıkça Sorulanlar</a></li>
                            <li><a href="#" id="btn5" class="py-2 d-block">Ödeme Yöntemleri</a></li>
                            <li><a href="/CarPricing/Index/" class="py-2 d-block">Kiralama</a></li>
                            <li><a href="#" id="btn6" class="py-2 d-block">Nasıl Çalışır</a></li>
                            <li><a href="/Contact/Index/" class="py-2 d-block">Bize Yazın</a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-md">
                    <div class="ftco-footer-widget mb-4">
                        <h2 class="ftco-heading-2">İletişim</h2>
                        <div class="block-23 mb-3">
                            <ul>
                                <li><span class="icon icon-map-marker"></span><span class="text">@item.Address</span></li>
                                <li><span class="icon icon-phone"></span><span class="text">@item.Phone</span></li>
                                <li><span class="icon icon-envelope"></span><span class="text">@item.Email</span></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row footer-bottom">
                <div class="col-md-12 text-center">
                    <p>
                        Copyright &copy; <script>document.write(new Date().getFullYear());</script>
                        <strong>CarBook</strong> | Tüm Hakları Saklıdır.
                    </p>
                </div>
            </div>
        </div>
    </footer>
}
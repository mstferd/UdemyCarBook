<style>
    /* Premium Renk Paleti */
    :root {
        --main-orange: #ff9f1c;
        --dark-blue: #2c3e50;
    }

    /* Ana Buton: Dolu Turuncu */
    .btn-theme-primary {
        background-color: var(--main-orange) !important;
        border: none !important;
        color: #fff !important;
        font-weight: 600;
        border-radius: 5px;
        transition: 0.3s;
    }

        .btn-theme-primary:hover {
            background-color: #e68a00 !important;
            box-shadow: 0 4px 15px rgba(255, 159, 28, 0.3);
            transform: translateY(-1px);
        }

    /* İkincil Buton: Sade ve Şık (Hover: Lacivert) */
    .btn-theme-outline {
        background-color: #f8f9fa !important;
        border: 1px solid #ddd !important;
        color: #666 !important;
        font-weight: 600;
        border-radius: 5px;
        transition: 0.3s;
    }

        .btn-theme-outline:hover {
            background-color: var(--dark-blue) !important;
            color: #fff !important;
            border-color: var(--dark-blue) !important;
        }

    /* Fiyat Alanı: Zarif Turuncu */
    .theme-orange {
        color: var(--main-orange) !important;
        font-weight: 800 !important;
        font-size: 1.1rem;
    }

    /* Marka İsmi (Üst Yazı) */
    .cat {
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 11px;
        color: #b0b0b0;
    }
</style>

@model List<ResultLast5CarsWithBrandsDto>

<section class="ftco-section ftco-no-pt bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-12 heading-section text-center ftco-animate mb-5">
                <span class="subheading">Sizin İçin Önerilerimiz</span>
                <h2 class="mb-2">Öne Çıkan Araçlarımız</h2>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="carousel-car owl-carousel">
                    @foreach (var item in Model)
                    {
                        <div class="item">
                            <div class="car-wrap rounded ftco-animate">
                                <div class="img rounded d-flex align-items-end" style="background-image: url(@item.CoverImageUrl);">
                                </div>
                                <div class="text">
                                    <h2 class="mb-0"><a href="#">@item.Model</a></h2>
                                    <div class="d-flex mb-3">
                                        <span class="cat">@item.BrandName</span>
                                        <p class="price ml-auto theme-orange">
                                            @item.Price.ToString("N0") <small style="color: #999; font-weight: 400;">₺ / Günlük</small>
                                        </p>
                                    </div>
                                    <p class="d-flex mb-0 d-block">
                                        @* Admin kısmını sildik, metot adını ve ID yapısını düzelttik *@
                                        <a href="/Reservation/CreateReservation/@item.CarID" class="btn btn-theme-primary py-2 mr-1">Hemen Kirala</a>
                                        <a href="/Car/CarDetail/@item.CarID" class="btn btn-theme-outline py-2 ml-1">Detaylar</a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
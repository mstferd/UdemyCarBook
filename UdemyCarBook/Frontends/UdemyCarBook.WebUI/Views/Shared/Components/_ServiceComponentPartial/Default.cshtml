@model List<ResultServiceDto>
<style>
    /* Hizmetler Bölümü Sabit Ayarlar */
    .custom-services-section .subheading {
        color: #ff9f1c !important;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .custom-services-section h2 {
        color: #1c2731 !important;
        font-weight: 800;
    }

    /* İkon Daireleri - ARKA PLAN SABİT LACİVERT */
    .custom-services-section .icon {
        background: #1c2731 !important; /* Arka plan hep lacivert kalsın */
        width: 80px;
        height: 80px;
        border-radius: 50%;
        margin: 0 auto 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s ease, border-color 0.3s ease; /* Arka plan geçişini sildik */
        border: 2px solid transparent;
    }

        /* İKONUN ANA RENGİ: BEYAZ */
        .custom-services-section .icon span {
            color: #ffffff !important;
            font-size: 35px;
            transition: color 0.3s ease; /* Sadece renk değişimine odaklan */
        }

    /* KART ÜZERİNE GELİNCE (HOVER) */
    .custom-services-section .services-2:hover .icon {
        background: #1c2731 !important; /* Arka plan rengini değiştirme, yanıp sönmeyi kes */
        border-color: #ff9f1c; /* Sadece ince turuncu bir çerçeve belirsin */
        transform: translateY(-8px); /* Hafif yukarı kalkış */
    }

        /* İKON HOVER RENGİ: SADECE TURUNCU */
        .custom-services-section .services-2:hover .icon span {
            color: #ff9f1c !important; /* İkon beyazdan turuncuya yumuşakça döner */
        }

    /* Başlık ve Yazı Ayarları */
    .custom-services-section .heading {
        color: #1c2731 !important;
        font-weight: 700;
        transition: 0.3s;
    }

    .custom-services-section .services-2:hover .heading {
        color: #ff9f1c !important;
    }

    .custom-services-section p {
        color: rgba(28, 39, 49, 0.7);
    }
</style>

<section class="ftco-section custom-services-section">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <span class="subheading">Hizmetler</span>
                <h2 class="mb-3">Sizin İçin Hizmetlerimiz</h2>
            </div>
        </div>
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="services services-2 w-100 text-center ftco-animate">
                        <div class="icon d-flex align-items-center justify-content-center">
                            <span class="@item.IconUrl"></span>
                        </div>
                        <div class="text w-100">
                            <h3 class="heading mb-2">@item.Title</h3>
                            <p>@item.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>